{
  "name": "slug-from-text",
  "version": "1.0.2",
  "description": "Generate URL-friendly slugs from text. Zero dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["slug", "url", "seo", "string"],
  "author": "MaxGrushevsky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaxGrushevsky/slug.git"
  },
  "bugs": "https://github.com/MaxGrushevsky/slug/issues",
  "homepage": "https://github.com/MaxGrushevsky/slug#readme",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
