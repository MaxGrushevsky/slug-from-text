{
  "name": "slug-from-text",
  "version": "1.0.4",
  "description": "Generate URL-friendly slugs from text. Zero dependencies.",
  "keywords": ["slug", "url", "seo", "string"],
  "author": "MaxGrushevsky",
  "license": "MIT",
  "repository": {
  "type": "git",
  "url": "https://github.com/MaxGrushevsky/slug-from-text.git"
  },
  "homepage": "https://github.com/MaxGrushevsky/slug-from-text#readme",
  "bugs": {
  "url": "https://github.com/MaxGrushevsky/slug-from-text/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
